# OpenRouter AI (https://openrouter.ai/keys)
# Supports: OpenAI, Anthropic, Mistral, Llama, Gemini and 100+ models
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=mistralai/mistral-7b-instruct

# Google Vision API (OCR)
GOOGLE_VISION_API_KEY=AIza...

# DeepL Translation (optional — fallback to AI if not set)
DEEPL_API_KEY=

# Vault
VAULT_PASSPHRASE=

# Backup (S3-compatible, optional)
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Email (SMTP, optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
